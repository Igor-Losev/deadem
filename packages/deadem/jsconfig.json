{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
        "#src/*": [ "./src/*" ],
        "#data/*": [ "./src/data/*" ],
        "#providers/*": [ "./src/providers/*" ]
    },
    "moduleResolution": "nodenext",
    "checkJs": true,
    "module": "nodenext",
    "strictNullChecks": true,
    "resolveJsonModule": true
  },
  "exclude": [ "node_modules" ]
}
