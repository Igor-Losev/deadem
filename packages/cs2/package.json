{
  "name": "@deademx/cs2",
  "version": "3.4.1",
  "description": "Counter-Strike 2 (Source 2) demo and replay parser with playback support for Node.js and browsers",
  "author": "Igor Losev",
  "license": "MIT",
  "bugs": "https://github.com/Igor-Losev/deadem/issues",
  "homepage": "https://deadem.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Igor-Losev/deadem.git",
    "directory": "packages/cs2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "deadem",
    "cs2",
    "counter-strike",
    "counter-strike-2",
    "cs2-parser",
    "cs2-demo-parser",
    "cs2-replay-parser",
    "valve",
    "source-2",
    "source2",
    "dem",
    "demo",
    "replay",
    "parser",
    "player",
    "demo-parser",
    "demoparser",
    "replay-parser",
    "replayparser",
    "nodejs",
    "browser"
  ],
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "vite build",
    "lint": "eslint",
    "proto:json": "node ./../../scripts/proto-schema-build.js --package=cs2",
    "proto:sync": "node ./../../.github/scripts/proto-sync.mjs cs2"
  },
  "files": [
    "dist/**",
    "index.js",
    "proto/compiled/**",
    "src/**"
  ],
  "imports": {
    "#src/*.js": "./src/*.js",
    "#bootstrap/*.js": "./src/bootstrap/*.js",
    "#data/*.js": "./src/data/*.js",
    "#providers/ProtoProvider.instance.js": {
      "node": "./src/providers/ProtoProvider.node.instance.js",
      "browser": "./src/providers/ProtoProvider.browser.instance.js"
    }
  },
  "dependencies": {
    "@deademx/engine": "3.4.1"
  }
}
